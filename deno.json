{
  "imports": {
    "@contracts/": "./packages/contracts/",
    "@kafka/": "./packages/kafka/",
    "std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "check": "deno check apps/api-gateway/main.ts apps/payment-ingest/main.ts apps/subscription-service/main.ts apps/expiry-worker/main.ts",
    "test": "deno test packages/contracts",
    "dev:api": "deno run -A apps/api-gateway/main.ts",
    "dev:ingest": "deno run -A apps/payment-ingest/main.ts",
    "dev:subs": "deno run -A apps/subscription-service/main.ts",
    "dev:expiry": "deno run -A apps/expiry-worker/main.ts"
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
